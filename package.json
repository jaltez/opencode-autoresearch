{
  "name": "@jaltez/opencode-autoresearch",
  "displayName": "OpenCode Autoresearch",
  "version": "0.1.1",
  "description": "OpenCode Autoresearch loop, benchmark, dashboard, and finalize plugin.",
  "private": false,
  "license": "MIT",
  "author": "Javier Altez",
  "type": "module",
  "keywords": [
    "opencode",
    "autoresearch",
    "benchmark",
    "experiments",
    "plugin"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "exports": {
    "./server": "./dist/server/index.js",
    "./tui": "./dist/tui/index.js"
  },
  "scripts": {
    "build": "bun run build:server && bun run build:tui",
    "build:server": "bun build ./src/server/index.ts --outdir ./dist/server --target bun",
    "build:tui": "bun run ./scripts/build-tui.ts",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.14.46",
    "@opencode-ai/sdk": "1.14.46",
    "@opentui/solid": "^0.2.7",
    "effect": "4.0.0-beta.59",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/bun": "1.3.13",
    "typescript": "6.0.3"
  }
}
